{
  "batch_size": 64,
  "dataset": "cifar10",
  "dataset_root": "./data",
  "early_stopping": {
    "enabled": true,
    "min_delta_pp": 0.1,
    "patience_epochs": 20,
    "warmup_epochs": 30
  },
  "epochs": 1,
  "learning_rate": 0.1,
  "model": "hybrid",
  "momentum": 0.9,
  "num_classes": 10,
  "num_workers": 4,
  "scheduler": "none",
  "seed": 42,
  "split_seed": 1337,
  "summary_log_interval_epochs": 10,
  "val_interval_epochs": 1,
  "weight_decay": 0.0005,
  "width_multiplier": 1.0
}
